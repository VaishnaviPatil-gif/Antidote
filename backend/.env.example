# Antidote+ backend — copy this file to `.env` and fill in real values.
# The Gemini API key is read ONLY here, server-side. It is never sent to,
# embedded in, or reachable from the frontend.

# Your Google Gemini API key (leave blank to run in safe-fallback mode).
GEMINI_API_KEY=

# Gemini model used for vision (snake ID) and text (summary, severity, voice).
# NOTE: each model has its OWN daily free-tier quota (~20 req/day). If flash is
# exhausted mid-demo, switch to gemini-2.5-flash-lite for a fresh bucket.
GEMINI_MODEL=gemini-2.5-flash-lite

# Comma-separated origins allowed by CORS. Includes the Vite dev server and the
# Capacitor Android WebView origins so AI calls work in the packaged APK too.
ALLOWED_ORIGINS=http://localhost:5173,https://localhost,capacitor://localhost

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Below this confidence the identifier refuses to name a species and returns
# the safe default (assume venomous). Safety-first policy floor is 0.90.
LOW_CONFIDENCE=0.9

# Sarvam AI key for Text-to-Speech and Speech-to-Text (voice assistant feature).
# Leave blank to disable voice entirely (the rest of the app is unaffected).
SARVAM_API_KEY=

# Sarvam TTS voice. MUST be a bulbul:v3 speaker (priya, neha, pooja, kavya,
# shreya, …). v2 voices like "anushka"/"meera" return a 400 on bulbul:v3.
SARVAM_SPEAKER=priya

# Secret used to sign hospital-dashboard login tokens. Override in production.
AUTH_SECRET=antidote-dev-secret-change-me
